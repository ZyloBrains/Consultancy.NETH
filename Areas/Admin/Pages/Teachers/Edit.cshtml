@page "/admin/teachers/edit/{id}"
@model EditTeacherModel
@inject ApplicationDbContext Context
@{
    ViewData["Title"] = "Edit Teacher";
}

<div class="bg-white rounded-xl shadow p-6">
    <h2 class="text-xl font-semibold mb-6">Edit Teacher</h2>
    <form method="post">
        <input type="hidden" name="Id" value="@Model.Teacher.Id" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                <input type="text" name="Name" value="@Model.Teacher.Name"
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" required />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Designation</label>
                <input type="text" name="Designation" value="@Model.Teacher.Designation"
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Photo URL</label>
                <input type="text" name="Photo" value="@Model.Teacher.Photo"
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Display Order</label>
                <input type="number" name="DisplayOrder" value="@Model.Teacher.DisplayOrder"
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Facebook</label>
                <input type="text" name="Facebook" value="@Model.Teacher.Facebook"
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">LinkedIn</label>
                <input type="text" name="LinkedIn" value="@Model.Teacher.LinkedIn"
                       class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
            </div>
            <div class="flex items-center space-x-6">
                <label class="flex items-center"><input type="checkbox" name="IsFeatured" class="mr-2"
                                                            checked="@Model.Teacher.IsFeatured" />Featured</label>
                    <label class="flex items-center"><input type="checkbox" name="IsActive" class="mr-2"
                                                                checked="@Model.Teacher.IsActive" />Active</label>
                    </div>
                </div>
                <div class="mt-6">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Bio</label>
                    <textarea name="Bio" rows="4"
                              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">@Model.Teacher.Bio</textarea>
                </div>
                <div class="mt-6 flex space-x-4">
                    <button type="submit" class="bg-purple-600 text-white px-6 py-2 rounded-lg hover:bg-purple-700">Update
                        Teacher</button>
                        <a href="/admin/teachers" class="border border-gray-300 px-6 py-2 rounded-lg hover:bg-gray-50">Cancel</a>
                    </div>
                </form>
            </div>

@functions {
    public class EditTeacherModel : PageModel
    {
        private readonly ApplicationDbContext _context;
        public EditTeacherModel(ApplicationDbContext context) => _context = context;
        
        public Teacher Teacher { get; set; }
        
        public async Task OnGetAsync(int id)
        {
            Teacher = await _context.Teachers.FindAsync(id);
            if (Teacher == null)
            {
                Response.Redirect("/admin/teachers");
            }
        }
        
        public async Task OnPostAsync()
        {
            var id = int.Parse(Request.Form["Id"].ToString());
            var teacher = await _context.Teachers.FindAsync(id);
            
            if (teacher == null)
            {
                Response.Redirect("/admin/teachers");
                return;
            }
            
            teacher.Name = Request.Form["Name"].ToString();
            teacher.Designation = Request.Form["Designation"].ToString();
            teacher.Photo = Request.Form["Photo"].ToString();
            teacher.Bio = Request.Form["Bio"].ToString();
            teacher.Facebook = Request.Form["Facebook"].ToString();
            teacher.LinkedIn = Request.Form["LinkedIn"].ToString();
            teacher.DisplayOrder = int.Parse(Request.Form["DisplayOrder"].ToString());
            teacher.IsFeatured = Request.Form["IsFeatured"].Count > 0;
            teacher.IsActive = Request.Form["IsActive"].Count > 0;
            teacher.UpdatedAt = DateTime.UtcNow;
            
            await _context.SaveChangesAsync();
            Response.Redirect("/admin/teachers");
        }
    }
}
