@page
@model AdminTeachersModel
@inject ApplicationDbContext Context
@{
    var teachers = Context.Teachers.OrderBy(t => t.DisplayOrder).ToList();
    ViewData["Title"] = "Teachers";
}

<div class="bg-white rounded-xl shadow overflow-hidden">
    <div class="p-6 flex justify-between items-center">
        <h2 class="text-xl font-semibold">Teachers</h2>
        <a href="/admin/teachers/create" class="bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700">Add New Teacher</a>
    </div>
    <table class="w-full">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Designation</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Featured</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            @foreach (var teacher in teachers)
            {
                <tr>
                    <td class="px-6 py-4">@teacher.Name</td>
                    <td class="px-6 py-4">@teacher.Designation</td>
                    <td class="px-6 py-4">@(teacher.IsFeatured ? "Yes" : "No")</td>
                    <td class="px-6 py-4"><span class="px-2 py-1 text-xs rounded-full @(teacher.IsActive ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">@(teacher.IsActive ? "Active" : "Inactive")</span></td>
                    <td class="px-6 py-4">
                        <a href="/admin/teachers/edit/@teacher.Id" class="text-blue-600 hover:underline mr-3">Edit</a>
                        <a href="/admin/teachers/delete/@teacher.Id" class="text-red-600 hover:underline" onclick="return confirm('Are you sure?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@functions {
    public class AdminTeachersModel : PageModel { public void OnGet() { } }
}