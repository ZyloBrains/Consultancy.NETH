@page
@model Consultancy.Areas.Admin.Pages.DocumentRequirements.DeleteModel
@{
    ViewData["Title"] = "Delete Document Requirement";
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6 text-red-600">Delete Document Requirement</h1>

    <div class="bg-white shadow-md rounded-lg p-6 max-w-lg">
        <h3 class="text-xl mb-4">Are you sure you want to delete this?</h3>
        
        <dl class="mb-6">
            <dt class="font-bold">Name</dt>
            <dd class="mb-2">@Model.DocumentRequirement.Name</dd>
            
            <dt class="font-bold">Description</dt>
            <dd class="mb-2">@Model.DocumentRequirement.Description</dd>
            
            <dt class="font-bold">Display Order</dt>
            <dd class="mb-2">@Model.DocumentRequirement.DisplayOrder</dd>
        </dl>

        <form method="post">
            <input type="hidden" asp-for="DocumentRequirement.Id" />
            <div class="flex items-center justify-between">
                <button type="submit" class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded">
                    Delete
                </button>
                <a asp-page="Index" class="text-gray-600 hover:text-gray-800">Back to List</a>
            </div>
        </form>
    </div>
</div>
