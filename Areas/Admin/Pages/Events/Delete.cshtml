@page "/admin/events/delete/{id}"
@model Consultancy.NETH.Areas.Admin.Pages.Events.DeleteModel
@{
    ViewData["Title"] = "Delete Event";
}

<div class="mb-6">
    <a href="/admin/events" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800">
        <i class="fa fa-arrow-left"></i> Back to Events
    </a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Delete Event</h2>

<div class="bg-white rounded-lg shadow-sm p-6">
    <div class="mb-6">
        <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center">
                <i class="fa fa-exclamation-triangle text-2xl text-red-600"></i>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-gray-800">Confirm Deletion</h3>
                <p class="text-sm text-gray-600">Are you sure you want to delete this event?</p>
            </div>
        </div>
    </div>

    <!-- Event Details -->
    <div class="bg-gray-50 rounded-lg p-4 mb-6">
        <h4 class="font-semibold text-gray-800 mb-2">@Model.Input.Title</h4>
        <div class="text-sm text-gray-600 space-y-1">
            <div><i class="fa fa-calendar text-red-500 mr-2"></i> @Model.Input.EventDate.ToString("yyyy-MM-dd HH:mm")</div>
            @if (!string.IsNullOrEmpty(Model.Input.Location))
            {
                <div><i class="fa fa-map-marker text-red-500 mr-2"></i> @Model.Input.Location</div>
            }
            <div>
                <i class="fa fa-info-circle text-red-500 mr-2"></i>
                Status: @if (Model.Input.IsActive) { <span class="text-green-600">Active</span> } else { <span class="text-gray-600">Inactive</span> }
            </div>
        </div>
    </div>

    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6">
        <div class="flex items-center gap-2">
            <i class="fa fa-warning text-yellow-600"></i>
            <p class="text-sm text-yellow-700">
                <strong>Warning:</strong> This action cannot be undone. The event will be permanently deleted.
            </p>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Input.Id" />
        
        <div class="flex gap-4">
            <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700">
                <i class="fa fa-trash mr-2"></i> Delete Event
            </button>
            <a href="/admin/events" class="bg-gray-200 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-300">
                Cancel
            </a>
        </div>
    </form>
</div>
