@page "/admin/events/edit/{id}"
@model Consultancy.NETH.Areas.Admin.Pages.Events.EditModel
@{
    ViewData["Title"] = "Edit Event";
}

<div class="mb-6">
    <a href="/admin/events" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800">
        <i class="fa fa-arrow-left"></i> Back to Events
    </a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Edit Event</h2>

<form method="post" class="bg-white rounded-lg shadow-sm p-6">
    <input type="hidden" asp-for="Input.Id" />
    
    <div class="space-y-6">
        <!-- Title -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Title (English)</label>
            <input asp-for="Input.Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
            <span asp-validation-for="Input.Title" class="text-red-500 text-sm"></span>
        </div>

        <!-- Title Nepali -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Title (Nepali)</label>
            <input asp-for="Input.TitleNp" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
        </div>

        <!-- Slug -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Slug</label>
            <input asp-for="Input.Slug" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
            <span asp-validation-for="Input.Slug" class="text-red-500 text-sm"></span>
        </div>

        <!-- Event Date -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Event Date & Time</label>
            <input asp-for="Input.EventDate" type="datetime-local" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
        </div>

        <!-- Location -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Location</label>
            <input asp-for="Input.Location" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
        </div>

        <!-- Image -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Image Path</label>
            <input asp-for="Input.Image" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="~/images/event.jpg" />
        </div>

        <!-- Description -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Description (English)</label>
            <textarea asp-for="Input.Description" rows="5" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
        </div>

        <!-- Description Nepali -->
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Description (Nepali)</label>
            <textarea asp-for="Input.DescriptionNp" rows="5" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
        </div>

        <!-- Is Active -->
        <div class="flex items-center gap-2">
            <input asp-for="Input.IsActive" class="w-5 h-5 text-blue-600" />
            <label asp-for="Input.IsActive" class="text-sm font-medium text-gray-700">Active</label>
        </div>
    </div>

    <!-- Buttons -->
    <div class="flex gap-4 mt-8 pt-6 border-t">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
            <i class="fa fa-save mr-2"></i> Save Changes
        </button>
        <a href="/admin/events" class="bg-gray-200 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-300">
            Cancel
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
