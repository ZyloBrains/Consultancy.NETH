<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/css/output.css" />
</head>
<body class="bg-gray-100">
    <div class="flex h-screen">
        <aside class="w-64 bg-primary text-white flex-shrink-0">
            <div class="p-6"><a href="/admin" class="flex items-center"><img src="~/images/neth_logo.jpg" alt="Logo" class="h-8 w-auto" /></a></div>
            <nav class="mt-6">
                <a href="/admin" class="flex items-center px-6 py-3 hover:bg-primary-dark">Dashboard</a>
                <a href="/admin/courses" class="flex items-center px-6 py-3 hover:bg-primary-dark">Courses</a>
                <a href="/admin/countries" class="flex items-center px-6 py-3 hover:bg-primary-dark">Countries</a>
                <a href="/admin/teachers" class="flex items-center px-6 py-3 hover:bg-primary-dark">Teachers</a>
                <a href="/admin/blogs" class="flex items-center px-6 py-3 hover:bg-primary-dark">Blogs</a>
                <a href="/admin/events" class="flex items-center px-6 py-3 hover:bg-primary-dark">Events</a>
                <a href="/admin/inquiries" class="flex items-center px-6 py-3 hover:bg-primary-dark">Inquiries</a>
            </nav>
        </aside>
        <div class="flex-1 flex flex-col overflow-hidden">
            <header class="bg-white shadow-sm py-4 px-6 flex justify-between items-center">
                <h1 class="text-xl font-semibold">@ViewData["Title"]</h1>
                <a href="/" target="_blank" class="text-gray-600 hover:text-primary">View Site</a>
            </header>
            <main class="flex-1 overflow-y-auto p-6">@RenderBody()</main>
        </div>
    </div>
</body>
</html>