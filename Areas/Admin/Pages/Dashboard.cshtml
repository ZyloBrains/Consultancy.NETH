@page "/admin"
@model Consultancy.NETH.Areas.Admin.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Cards Row -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <!-- Card 1 - Students -->
    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-blue-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 mb-1">Total Students</p>
                <h3 class="text-2xl font-bold text-gray-800">@Model.TotalStudents</h3>
                <p class="text-xs text-green-600 mt-2">
                    <span class="font-semibold">+12%</span> vs last month
                </p>
            </div>
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z">
                    </path>
                </svg>
            </div>
        </div>
    </div>

    <!-- Card 2 - Courses -->
    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-green-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 mb-1">Active Courses</p>
                <h3 class="text-2xl font-bold text-gray-800">@Model.TotalCourses</h3>
                <p class="text-xs text-green-600 mt-2">
                    <span class="font-semibold">+5%</span> vs last month
                </p>
            </div>
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253">
                    </path>
                </svg>
            </div>
        </div>
    </div>

    <!-- Card 3 - Countries -->
    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-purple-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 mb-1">Countries</p>
                <h3 class="text-2xl font-bold text-gray-800">@Model.TotalCountries</h3>
                <p class="text-xs text-green-600 mt-2">
                    <span class="font-semibold">+2</span> new this year
                </p>
            </div>
            <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                    </path>
                </svg>
            </div>
        </div>
    </div>

    <!-- Card 4 - Inquiries -->
    <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 border-orange-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm text-gray-600 mb-1">New Inquiries</p>
                <h3 class="text-2xl font-bold text-gray-800">@Model.NewInquiries</h3>
                <p class="text-xs text-orange-600 mt-2">
                    <span class="font-semibold">@Model.PendingDocuments</span> pending docs
                </p>
            </div>
            <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                    </path>
                </svg>
            </div>
        </div>
    </div>
</div>

<!-- Recent Items Section -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Recent Students -->
    <div class="bg-white rounded-lg shadow-sm p-6 lg:col-span-2">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-semibold text-gray-800">Recent Students</h3>
            <a href="/admin/students" class="text-sm text-blue-600 hover:underline">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b">
                        <th class="text-left py-3 px-4 font-semibold text-sm text-gray-600">Name</th>
                        <th class="text-left py-3 px-4 font-semibold text-sm text-gray-600">Email</th>
                        <th class="text-left py-3 px-4 font-semibold text-sm text-gray-600">Course</th>
                        <th class="text-left py-3 px-4 font-semibold text-sm text-gray-600">Country</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model.RecentStudents)
                    {
                        <tr class="border-b hover:bg-gray-50">
                            <td class="py-3 px-4">
                                <div class="flex items-center space-x-3">
                                    <div
                                        class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm font-bold">
                                        @student.Name.Substring(0, 1)
                                    </div>
                                    <span class="font-medium">@student.Name</span>
                                </div>
                            </td>
                            <td class="py-3 px-4 text-sm text-gray-600">@student.Email</td>
                            <td class="py-3 px-4 text-sm text-gray-600">@student.CourseName</td>
                            <td class="py-3 px-4 text-sm text-gray-600">@student.CountryName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Inquiries & Quick Actions -->
    <div class="space-y-6">
        <!-- Quick Stats -->
        <div class="bg-white rounded-lg shadow-sm p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Quick Stats</h3>
            <div class="space-y-4">
                <div class="flex justify-between items-center pb-3 border-b">
                    <span class="text-gray-600">Teachers</span>
                    <span class="font-bold text-blue-600">@Model.TotalTeachers</span>
                </div>
                <div class="flex justify-between items-center pb-3 border-b">
                    <span class="text-gray-600">Blogs</span>
                    <span class="font-bold text-green-600">@Model.TotalBlogs</span>
                </div>
                <div class="flex justify-between items-center pb-3 border-b">
                    <span class="text-gray-600">Pending Docs</span>
                    <span class="font-bold text-orange-600">@Model.PendingDocuments</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-gray-600">New Inquiries</span>
                    <span class="font-bold text-purple-600">@Model.NewInquiries</span>
                </div>
            </div>
        </div>

        <!-- Recent Inquiries -->
        <div class="bg-white rounded-lg shadow-sm p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Recent Inquiries</h3>
            <div class="space-y-3">
                @foreach (var inquiry in Model.RecentInquiries)
                {
                    <div class="flex justify-between items-start py-2 border-b">
                        <div>
                            <p class="font-medium text-sm">@inquiry.Name</p>
                            <p class="text-xs text-gray-500">@inquiry.Subject</p>
                        </div>
                        <span class="text-xs text-gray-400">@inquiry.CreatedAt.ToString("dd-MM-yyyy")</span>
                    </div>
                }
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-lg shadow-sm p-6">
            
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Quick Actions</h3>
            <div class="grid grid-cols-2 gap-3">
                <a href="/admin/courses/create"
                   class="bg-blue-600 text-white text-center py-2 rounded-lg text-sm hover:bg-blue-700">Add Course</a>
                <a href="/admin/countries/create"
                   class="bg-teal-600 text-white text-center py-2 rounded-lg text-sm hover:bg-teal-700">Add Country</a>
                <a href="/admin/teachers/create"
                       class="bg-purple-600 text-white text-center py-2 rounded-lg text-sm hover:bg-purple-700">Add
                    Teacher</a>
                    <a href="/admin/students/create"
                           class="bg-orange-600 text-white text-center py-2 rounded-lg text-sm hover:bg-orange-700">Add
                        Student</a>
                    </div>
                </div>
            </div>
        </div>
