@page
@model Consultancy.Areas.Admin.Pages.StudentDocuments.ManageModel
@{
    ViewData["Title"] = "Manage Documents - " + Model.Student?.Name;
}

<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold">Manage Documents</h1>
        <a asp-page="Index" class="text-gray-600 hover:text-gray-800">Back to List</a>
    </div>

    @if (Model.Student != null)
    {
        <div class="bg-white shadow-md rounded-lg p-6 mb-6">
            <h2 class="text-xl font-bold mb-2">@Model.Student.Name</h2>
            @if (!string.IsNullOrEmpty(Model.Student.GoogleDriveFolderUrl))
            {
                <a href="@Model.Student.GoogleDriveFolderUrl" target="_blank" 
                   class="text-blue-500 hover:underline">Open Google Drive Folder</a>
            }
        </div>
    }

    <div class="bg-white shadow-md rounded-lg p-6">
        <h3 class="text-lg font-bold mb-4">Document Checklist</h3>
        
        <table class="min-w-full">
            <thead class="bg-gray-100">
                <tr>
                    <th class="px-4 py-2 text-left">Document</th>
                    <th class="px-4 py-2 text-left">Status</th>
                    <th class="px-4 py-2 text-left">File Name</th>
                    <th class="px-4 py-2 text-left">Last Checked</th>
                    <th class="px-4 py-2 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in Model.Requirements)
                {
                    var doc = Model.Documents.FirstOrDefault(d => d.DocumentRequirementId == req.Id);
                    <tr class="border-t">
                        <td class="px-4 py-3">@req.Name</td>
                        <td class="px-4 py-3">
                            @if (doc != null)
                            {
                                <span class="px-2 py-1 text-xs rounded-full @(doc.Status == "Verified" ? "bg-blue-100 text-blue-800" : doc.Status == "Submitted" ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800")">
                                    @doc.Status
                                </span>
                            }
                            else
                            {
                                <span class="px-2 py-1 text-xs rounded-full bg-red-100 text-red-800">Pending</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-sm">@doc?.FileName</td>
                        <td class="px-4 py-3 text-sm">@doc?.LastCheckedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="px-4 py-3">
                            @if (doc == null)
                            {
                                <form method="post" asp-handler="Add">
                                    <input type="hidden" name="studentId" value="@Model.StudentId" />
                                    <input type="hidden" name="requirementId" value="@req.Id" />
                                    <input type="text" name="fileName" placeholder="File name" class="border rounded px-2 py-1 text-sm mr-2" />
                                    <button type="submit" class="bg-green-500 text-white px-3 py-1 rounded text-sm">Add</button>
                                </form>
                            }
                            else
                            {
                                <div class="flex gap-2">
                                    <form method="post" asp-handler="Update">
                                        <input type="hidden" name="documentId" value="@doc.Id" />
                                        <input type="hidden" name="status" value="Verified" />
                                        <button type="submit" class="text-blue-500 text-sm">Verify</button>
                                    </form>
                                    <form method="post" asp-handler="Update">
                                        <input type="hidden" name="documentId" value="@doc.Id" />
                                        <input type="hidden" name="status" value="Pending" />
                                        <button type="submit" class="text-red-500 text-sm">Reset</button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
