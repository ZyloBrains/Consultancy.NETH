@page
@model Consultancy.Areas.Admin.Pages.StudentDocuments.IndexModel
@{
    ViewData["Title"] = "Student Documents";
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Student Documents</h1>

    <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <table class="min-w-full">
            <thead class="bg-gray-100">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Completion</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documents</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Checked</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var item in Model.StudentSummaries)
                {
                    <tr>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="font-medium">@item.StudentName</div>
                            @if (!string.IsNullOrEmpty(item.GoogleDriveFolderUrl))
                            {
                                <a href="@item.GoogleDriveFolderUrl" target="_blank" class="text-blue-500 text-sm hover:underline">
                                    View Folder
                                </a>
                            }
                        </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        @if (item.TotalDocuments > 0)
                        {
                            var percentage = (int)Math.Round((double)item.SubmittedCount / item.TotalDocuments * 100);
                            <div class="flex items-center">
                                <div class="w-16 bg-gray-200 rounded-full h-2.5 mr-2">
                                    <div class="bg-blue-600 h-2.5 rounded-full" style="width: @(percentage)%"></div>
                                </div>
                                <span class="text-sm">@percentage%</span>
                            </div>
                        }
                        else
                        {
                            <span class="text-gray-400">N/A</span>
                        }
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        @item.SubmittedCount / @item.TotalDocuments submitted
                    </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (item.SubmittedCount == item.TotalDocuments && item.TotalDocuments > 0)
                            {
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                    Complete
                                </span>
                            }
                            else if (item.SubmittedCount > 0)
                            {
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                                    Partial
                                </span>
                            }
                            else
                            {
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                                    Pending
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @if (item.LastCheckedAt.HasValue)
                            {
                                @item.LastCheckedAt.Value.ToString("yyyy-MM-dd HH:mm")
                            }
                            else
                            {
                                <span class="text-gray-400">Never</span>
                            }
                        </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a asp-page="Verify" asp-route-studentid="@item.StudentId" class="text-indigo-600 hover:text-indigo-900 mr-4">Verify</a>
                    <a asp-page="Manage" asp-route-studentid="@item.StudentId" class="text-green-600 hover:text-green-900 mr-4">Manage</a>
                </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
