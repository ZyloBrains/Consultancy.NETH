@page "/contact"
@model ContactModel
@inject IContactService ContactService
@{
    ViewData["Title"] = "Contact";
}

<section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-4xl font-bold text-center mb-12">Contact Us</h1>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white rounded-xl shadow-lg p-8">
                <h2 class="text-xl font-bold mb-6">Send Message</h2>
                @if (TempData["Success"] != null)
                {
                    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">Thank you! Your message has been sent.</div>
                }
                <form method="post">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                            <input type="text" name="Name" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                            <input type="email" name="Email" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" required />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                            <input type="tel" name="Phone" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
                            <input type="text" name="Subject" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
                            <textarea name="Message" rows="5" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" required></textarea>
                        </div>
                        <button type="submit" class="w-full bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700">Send Message</button>
                    </div>
                </form>
            </div>
            <div class="space-y-6">
                <div class="bg-white rounded-xl shadow-lg p-8">
                    <h3 class="text-xl font-bold mb-4">Office Information</h3>
                    <div class="space-y-4">
                        <div class="flex items-start">
                            <span class="text-blue-600 mr-4">📍</span>
                            <div><h4 class="font-semibold">Putalisadak Office</h4><p class="text-gray-600">Putalisadak-28, Kathmandu</p></div>
                        </div>
                        <div class="flex items-start">
                            <span class="text-blue-600 mr-4">📞</span>
                            <div><h4 class="font-semibold">Phone</h4><p class="text-gray-600">+977 01-4168340</p></div>
                        </div>
                        <div class="flex items-start">
                            <span class="text-blue-600 mr-4">✉️</span>
                            <div><h4 class="font-semibold">Email</h4><p class="text-gray-600">info@consultancy.com</p></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@functions {
    public class ContactModel : PageModel {
        private readonly IContactService _contactService;
        public ContactModel(IContactService contactService) => _contactService = contactService;
        
        public async Task OnPost() {
            var inquiry = new ContactInquiry {
                Name = Request.Form["Name"].ToString(),
                Email = Request.Form["Email"].ToString(),
                Phone = Request.Form["Phone"].ToString(),
                Subject = Request.Form["Subject"].ToString(),
                Message = Request.Form["Message"].ToString(),
                Status = "New"
            };
            await _contactService.CreateAsync(inquiry);
            TempData["Success"] = "true";
        }
    }
}