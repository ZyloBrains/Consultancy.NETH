@page "/teachers"
@model TeachersModel
@inject ITeacherService TeacherService
@{
    var teachers = await TeacherService.GetAllAsync();
    ViewData["Title"] = "Teachers";
}

<section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-4xl font-bold text-center mb-12">Our Teachers</h1>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var teacher in teachers)
            {
                <div class="text-center p-6">
                    <div class="w-40 h-40 mx-auto rounded-full bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center mb-4">
                        <span class="text-4xl text-white font-bold">@(teacher.Name.Substring(0, 1))</span>
                    </div>
                    <h3 class="text-xl font-bold">@teacher.Name</h3>
                    <p class="text-blue-600">@teacher.Designation</p>
                </div>
            }
        </div>
    </div>
</section>

@functions {
    public class TeachersModel : PageModel { public async Task OnGet() => await Task.CompletedTask; }
}