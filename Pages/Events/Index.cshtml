@page "/events"
@model Consultancy.NETH.Pages.Events.IndexModel
@inject Consultancy.Services.IEventService EventService

@{
    ViewData["Title"] = "Events - NETH Educational Consultancy";
}

<section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
        <!-- Heading -->
        <div class="text-center mb-16">
            <span class="inline-flex items-center gap-2 bg-red-500/10 text-red-600 px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wider">
                Events
            </span>
            <h2 class="text-4xl md:text-5xl font-extrabold mt-5 mb-5 leading-tight">
                Upcoming <span class="text-red-600">Events</span>
            </h2>
            <p class="text-gray-600 max-w-2xl mx-auto text-lg">
                Stay updated with our latest events, webinars, and workshops.
            </p>
        </div>

        <!-- Events Grid -->
        @if (Model.Events.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var evt in Model.Events)
                {
                    <a href="/events/@evt.Slug" class="group bg-white rounded-2xl shadow-md hover:shadow-2xl transition-all duration-500 overflow-hidden border border-gray-100 transform hover:-translate-y-2">
                        <!-- Image -->
                        <div class="relative h-48 overflow-hidden">
                            @if (!string.IsNullOrEmpty(evt.Image))
                            {
                                <img src="~/@evt.Image" class="w-full h-full object-cover group-hover:scale-110 transition duration-700" />
                            }
                            else
                            {
                                <div class="w-full h-full bg-gradient-to-br from-red-100 to-red-200 flex items-center justify-center">
                                    <i class="fa fa-calendar text-6xl text-red-400"></i>
                                </div>
                            }
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                            
                            <!-- Date Badge -->
                            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-2 rounded-lg text-center">
                                <div class="text-red-600 font-bold text-lg">@evt.EventDate.ToString("dd")</div>
                                <div class="text-gray-600 text-xs font-semibold">@evt.EventDate.ToString("MMM")</div>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-6">
                            <div class="flex items-center gap-2 mb-3 text-sm text-gray-500">
                                <i class="fa fa-map-marker text-red-500"></i>
                                <span>@(evt.Location ?? "Location TBA")</span>
                            </div>

                            <h3 class="text-xl font-bold mb-3 group-hover:text-red-600 transition">
                                @evt.Title
                            </h3>

                            <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                                @(evt.Description ?? "Join us for this exciting event.")
                            </p>

                            <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                                <div class="flex items-center gap-2 text-sm text-gray-500">
                                    <i class="fa fa-clock-o text-red-500"></i>
                                    <span>@evt.EventDate.ToString("h:mm tt")</span>
                                </div>

                                <span class="inline-flex items-center gap-2 text-red-600 text-sm font-semibold group-hover:gap-3 transition-all">
                                    View Details
                                    <i class="fa fa-arrow-right"></i>
                                </span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <i class="fa fa-calendar-times text-6xl text-gray-300 mb-4"></i>
                <p class="text-gray-500 text-lg">No upcoming events at the moment.</p>
                <p class="text-gray-400 text-sm mt-2">Check back soon for new events!</p>
            </div>
        }
    </div>
</section>
