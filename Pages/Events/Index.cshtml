@page
@model EventsModel
@inject IEventService EventService
@{
    var events = await EventService.GetAllAsync();
    ViewData["Title"] = "Events";
}

<section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-4xl font-bold text-center mb-12">Events</h1>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @foreach (var evt in events)
            {
                <div class="bg-white rounded-xl shadow-md p-6">
                    <p class="text-blue-600 text-sm mb-2">@evt.EventDate.ToString("dd-MM-yyyy")</p>
                    <h3 class="text-lg font-bold mb-2">@evt.Title</h3>
                    <a href="/events/@evt.Slug" class="text-blue-600 font-medium">Read More →</a>
                </div>
            }
        </div>
    </div>
</section>

@functions {
    public class EventsModel : PageModel { public async Task OnGet() => await Task.CompletedTask; }
}