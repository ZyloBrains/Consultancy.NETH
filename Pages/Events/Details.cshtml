@page "/events/{slug}"
@model EventDetailsModel
@inject IEventService EventService

@{
    var evt = await EventService.GetBySlugAsync(ViewContext.RouteData.Values["slug"]?.ToString() ?? "");
    ViewData["Title"] = evt?.Title ?? "Event";
}

<section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
        @if (evt != null)
        {
            <div class="mb-8"><a href="/events" class="text-blue-600 hover:underline">← Events</a></div>
            <div class="bg-white rounded-xl shadow-lg p-8">
                <h1 class="text-4xl font-bold mb-6">@evt.Title</h1>
                <p class="text-gray-600 mb-4">@evt.EventDate.ToString("dd-MM-yyyy")</p>
                <div class="prose max-w-none">@Html.Raw(evt.Description)</div>
            </div>
        }
    </div>
</section>

@functions {
    public class EventDetailsModel : PageModel { public async Task OnGet() => await Task.CompletedTask; }
}