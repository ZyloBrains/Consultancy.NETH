@page "/events/{slug}"
@model Consultancy.NETH.Pages.Events.DetailsModel
@inject Consultancy.Services.IEventService EventService

@if (Model.Event == null)
{
    <div class="container mx-auto px-4 py-20 text-center">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">Event Not Found</h2>
        <p class="text-gray-600 mb-8">The event you're looking for doesn't exist or has been removed.</p>
        <a href="/events" class="inline-flex items-center gap-2 bg-red-500 text-white px-6 py-3 rounded-full font-semibold hover:bg-red-600 transition">
            <i class="fa fa-arrow-left"></i> Back to Events
        </a>
    </div>
}
else
{
    var evt = Model.Event;

    <section class="py-20 bg-gray-50">
        <div class="container mx-auto px-4 max-w-4xl">
            <!-- Back Button -->
            <a href="/events" class="inline-flex items-center gap-2 text-red-600 hover:text-red-700 mb-8 font-medium">
                <i class="fa fa-arrow-left"></i> Back to Events
            </a>

            <!-- Event Card -->
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                <!-- Image -->
                <div class="relative h-64 md:h-96 bg-gradient-to-br from-red-100 to-red-200">
                    @if (!string.IsNullOrEmpty(evt.Image))
                    {
                        <img src="~/@evt.Image" class="w-full h-full object-cover" alt="@evt.Title" />
                    }
                    else
                    {
                        <div class="w-full h-full flex items-center justify-center">
                            <i class="fa fa-calendar text-8xl text-red-400"></i>
                        </div>
                    }
                    
                    <!-- Event Date Overlay -->
                    <div class="absolute top-6 left-6 bg-white/95 backdrop-blur-md px-4 py-3 rounded-xl text-center shadow-lg">
                        <div class="text-red-600 font-bold text-2xl">@evt.EventDate.ToString("dd")</div>
                        <div class="text-gray-600 text-sm font-semibold">@evt.EventDate.ToString("MMM yyyy")</div>
                    </div>
                </div>

                <!-- Content -->
                <div class="p-8">
                    <!-- Title -->
                    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">
                        @evt.Title
                    </h1>

                    <!-- Meta Info -->
                    <div class="flex flex-wrap gap-6 mb-8 text-gray-600">
                        <div class="flex items-center gap-2">
                            <i class="fa fa-calendar text-red-500"></i>
                            <span>@evt.EventDate.ToString("dddd, MMMM dd, yyyy")</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fa fa-clock-o text-red-500"></i>
                            <span>@evt.EventDate.ToString("h:mm tt")</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fa fa-map-marker text-red-500"></i>
                            <span>@(evt.Location ?? "Location TBA")</span>
                        </div>
                    </div>

                    <!-- Divider -->
                    <div class="border-t border-gray-200 mb-8"></div>

                    <!-- Description -->
                    <div class="prose max-w-none">
                        @if (!string.IsNullOrEmpty(evt.Description))
                        {
                            <div class="text-gray-700 leading-relaxed">
                                @Html.Raw(evt.Description)
                            </div>
                        }
                        else
                        {
                            <p class="text-gray-400 italic">No description available for this event.</p>
                        }
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-col sm:flex-row gap-4 mt-10 pt-8 border-t border-gray-200">
                        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-red-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-red-600 transition">
                            <i class="fa fa-envelope"></i> Contact Us for More Info
                        </a>
                        <a href="/events" class="inline-flex items-center justify-center gap-2 border-2 border-red-500 text-red-500 px-8 py-3 rounded-full font-semibold hover:bg-red-500 hover:text-white transition">
                            <i class="fa fa-calendar"></i> View All Events
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
