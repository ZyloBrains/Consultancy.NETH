<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Consultancy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: {
        DEFAULT: '#004aad',
        dark: '#003380',
        light: '#1a65d4'
        },
        secondary: {
        DEFAULT: '#f4c430',
        dark: '#d4ab00'
        },
        accent: '#f4c430',
        dark: '#1f2937',
        light: '#f3f4f6'
        },
        container: {
        center: true,
        padding: '1rem'
        }
        }
        }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50">
    <header class="fixed w-full bg-white/95 backdrop-blur-sm shadow-sm z-50">
        <nav class="max-w-7xl mx-auto px-4">
            <div class="flex items-center justify-between h-16">
                <a href="/" class="flex items-center">
                    <img src="~/images/neth_logo.jpg" alt="Logo" class="h-10 w-auto" />
                </a>
                <div class="hidden md:flex items-center space-x-6">
                    <a href="/" class="text-gray-700 hover:text-primary">Home</a>
                    <a href="/courses" class="text-gray-700 hover:text-primary">Courses</a>
                    <a href="/countries" class="text-gray-700 hover:text-primary">Countries</a>
                    <a href="/teachers" class="text-gray-700 hover:text-primary">Teachers</a>
                    <a href="/blogs" class="text-gray-700 hover:text-primary">Blogs</a>
                    <a href="/events" class="text-gray-700 hover:text-primary">Events</a>
                    <a href="/about-us" class="text-gray-700 hover:text-primary">About Us</a>
                    <a href="/admin/identity/login" class="text-gray-700 hover:text-primary">Admin Login</a>
                </div>
            </div>
        </nav>
    </header>
    <main class="pt-16 min-h-screen">@RenderBody()</main>
    <footer class="bg-dark text-white py-12">
        <div class="max-w-7xl mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div>
                    <img src="~/images/neth_logo.jpg" alt="Logo" class="h-12 w-auto mb-4" />
                    <p class="text-gray-400">Your trusted education partner</p>
                </div>
                <div>
                    <h4 class="font-semibold mb-4">Quick Links</h4>
                    <ul class="space-y-2 text-gray-400">
                        <li><a href="/courses" class="hover:text-white">Courses</a></li>
                        <li><a href="/countries" class="hover:text-white">Countries</a></li>
                        <li><a href="/contact" class="hover:text-white">Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-semibold mb-4">Contact</h4>
                    <p class="text-gray-400">Kathmandu, Nepal</p>
                    <p class="text-gray-400">+977 01-4168340</p>
                </div>
                <div>
                    <h4 class="font-semibold mb-4">Follow Us</h4>
                    <div class="flex space-x-4">
                        <a href="#" class="text-gray-400 hover:text-primary">Facebook</a>
                        <a href="#" class="text-gray-400 hover:text-primary">Instagram</a>
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400">
                &copy; 2026 Consultancy. All rights reserved.
            </div>
        </div>
    </footer>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>