<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NETH Educational Consultancy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: {
        DEFAULT: '#004aad',
        dark: '#003380',
        light: '#1a65d4'
        },
        secondary: {
        DEFAULT: '#f4c430',
        dark: '#d4ab00'
        },
        red: {
        DEFAULT: '#dc3545',
        dark: '#c82333'
        }
        }
        }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        background: transparent !important;
        margin: 0;
        padding: 0;
        }

        html {
        background: transparent !important;
        }

        .nav-link {
        position: relative;
        display: inline-block;
        transition: color 0.3s ease;
        }

        .nav-link::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -4px;
        width: 0;
        height: 2px;
        background-color: #004aad;
        transition: width 0.3s ease;
        }

        .nav-link:hover::after {
        width: 100%;
        }
    </style>
</head>

<body class="flex flex-col min-h-screen">
    <!-- Navbar - White floating rounded bar -->
    <nav class="fixed top-3 left-1/2 transform -translate-x-1/2 w-[95%] sm:w-[90%] md:w-[85%] max-w-7xl z-50 bg-white shadow-lg rounded-xl md:rounded-2xl"
         id="main-navbar">
        <div class="px-4 sm:px-6 md:px-12">
            <div class="flex items-center justify-between py-2 md:py-1">
                <a href="/" class="flex items-center">
                    <img src="~/images/neth_logo.jpg" alt="NETH Logo" class="h-10 sm:h-12 md:h-14 lg:h-16 w-auto object-contain" />
                </a>
                <div class="hidden md:flex items-center space-x-4 lg:space-x-6">
                    <a href="/" class="nav-link text-red-600 hover:text-blue-600 font-medium text-sm lg:text-base">Home</a>
                    <a href="/courses"
                       class="nav-link text-red-600 hover:text-blue-600 font-medium text-sm lg:text-base">Courses</a>
                    <a href="/countries"
                       class="nav-link text-red-600 hover:text-blue-600 font-medium text-sm lg:text-base">Countries</a>
                    <a href="/teachers"
                       class="nav-link text-red-600 hover:text-blue-600 font-medium text-sm lg:text-base">Teachers</a>
                    <a href="/events" class="nav-link text-red-600 hover:text-blue-600 font-medium text-sm lg:text-base">Events</a>
                    <a href="/about-us" class="nav-link text-red-600 hover:text-blue-600 font-medium text-sm lg:text-base">About
                        Us</a>
                    </div>
                    <div class="flex items-center space-x-2">
                        <button class="relative w-8 h-8 sm:w-9 sm:h-9 bg-gray-200 rounded-full flex items-center justify-center hover:bg-gray-300 transition">
                            <i class="fa fa-user text-blue-600 text-xs sm:text-sm"></i>
                        </button>
                        
                        <a href="/contact"
                               class="hidden md:inline-block bg-white text-primary px-3 md:px-4 py-1 md:py-1.5 rounded-full hover:bg-blue-500 transition font-semibold text-xs md:text-sm">Get
                            Started</a>
                            <button class="md:hidden text-gray-700 p-1"
                                    onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                                <i class="fa fa-bars text-base"></i>
                            </button>
                        </div>
                    </div>
                    <!-- Mobile Menu -->
                    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-100 bg-white rounded-b-xl">
                        <div class="px-4 pt-2 space-y-1">
                            <a href="/" class="block py-2 text-gray-700 hover:text-red-500 hover:bg-gray-50 rounded-lg px-2 text-sm font-medium">Home</a>
                            <a href="/courses" class="block py-2 text-gray-700 hover:text-red-500 hover:bg-gray-50 rounded-lg px-2 text-sm font-medium">Courses</a>
                            <a href="/countries" class="block py-2 text-gray-700 hover:text-red-500 hover:bg-gray-50 rounded-lg px-2 text-sm font-medium">Countries</a>
                            <a href="/teachers" class="block py-2 text-gray-700 hover:text-red-500 hover:bg-gray-50 rounded-lg px-2 text-sm font-medium">Teachers</a>
                            <a href="/events" class="block py-2 text-gray-700 hover:text-red-500 hover:bg-gray-50 rounded-lg px-2 text-sm font-medium">Events</a>
                            <a href="/about-us" class="block py-2 text-gray-700 hover:text-red-500 hover:bg-gray-50 rounded-lg px-2 text-sm font-medium">About Us</a>
                            <a href="/contact" class="block py-2 text-red-500 font-semibold bg-red-50 rounded-lg px-2 text-sm">Get Started</a>
                        </div>
                    </div>
                </div>
            </nav>

            <main class="flex-grow">
                @RenderBody()
            </main>

           <footer class="bg-gray-950 text-white pt-20 pb-10 relative overflow-hidden">

    <!-- subtle glow -->
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 left-10 w-40 h-40 bg-red-500 rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-52 h-52 bg-blue-500 rounded-full blur-3xl"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">

        <!-- Main Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

            <!-- Logo & About -->
            <div>
                <img src="~/images/neth_logo.jpg" alt="NETH Logo" class="h-12 w-auto mb-5" />

                <p class="text-gray-400 text-sm leading-relaxed mb-5">
                    NETH Educational Consultancy is a leading education consultancy for abroad study, guiding students toward global opportunities.
                </p>

                <div class="flex gap-3">
                    <a class="w-10 h-10 rounded-lg bg-blue-600 hover:bg-blue-700 flex items-center justify-center transition">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a class="w-10 h-10 rounded-lg bg-pink-600 hover:bg-pink-700 flex items-center justify-center transition">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a class="w-10 h-10 rounded-lg bg-sky-500 hover:bg-sky-600 flex items-center justify-center transition">
                        <i class="fab fa-twitter"></i>
                    </a>
                </div>
            </div>

            <!-- Quick Links -->
            <div>
                <h4 class="text-lg font-semibold mb-5 text-white">Quick Links</h4>

                <ul class="space-y-3 text-gray-400">
                    <li><a href="/courses" class="hover:text-red-400 transition flex items-center gap-2"><i class="fa fa-chevron-right text-xs"></i>Courses</a></li>
                    <li><a href="/countries" class="hover:text-red-400 transition flex items-center gap-2"><i class="fa fa-chevron-right text-xs"></i>Countries</a></li>
                    <li><a href="/events" class="hover:text-red-400 transition flex items-center gap-2"><i class="fa fa-chevron-right text-xs"></i>Events</a></li>
                    <li><a href="/contact" class="hover:text-red-400 transition flex items-center gap-2"><i class="fa fa-chevron-right text-xs"></i>Contact</a></li>
                </ul>
            </div>

            <!-- Office 1 -->
            <div>
                <h4 class="text-lg font-semibold mb-5 text-white">Putalisadak Office</h4>

                <ul class="space-y-3 text-gray-400 text-sm">
                    <li class="flex gap-2 items-start"><i class="fa fa-phone text-red-500 mt-1"></i>+977 01-4168340</li>
                    <li class="flex gap-2 items-start"><i class="fa fa-mobile text-red-500 mt-1"></i>+977 9841012378</li>
                    <li class="flex gap-2 items-start"><i class="fa fa-envelope text-red-500 mt-1"></i>neth.edu@gmail.com</li>
                    <li class="flex gap-2 items-start"><i class="fa fa-map-marker text-red-500 mt-1"></i>Putalisadak-28, Kathmandu</li>
                </ul>
            </div>

            <!-- Office 2 -->
            <div>
                <h4 class="text-lg font-semibold mb-5 text-white">Shorakhutte Office</h4>

                <ul class="space-y-3 text-gray-400 text-sm">
                    <li class="flex gap-2 items-start"><i class="fa fa-phone text-red-500 mt-1"></i>(+977) 01-4383281</li>
                    <li class="flex gap-2 items-start"><i class="fa fa-mobile text-red-500 mt-1"></i>+977 9841773655</li>
                    <li class="flex gap-2 items-start"><i class="fa fa-envelope text-red-500 mt-1"></i>neth.edu@gmail.com</li>
                    <li class="flex gap-2 items-start"><i class="fa fa-map-marker text-red-500 mt-1"></i>Sorhakhutte-16, Kathmandu</li>
                </ul>
            </div>

        </div>

        <!-- Bottom -->
        <div class="border-t border-gray-800 pt-6 text-gray-400 text-sm flex flex-col md:flex-row items-center justify-center gap-2">

    <p>
        © @DateTime.Now.Year NETH Educational Consultancy. All rights reserved.
    </p>

    <span class="hidden md:inline">|</span>

    <p>
        Powered by 
        <a href="https://zylobrains.com" target="_blank" class="inline-flex items-center font-semibold ml-1 text-base">
            <span class="text-blue-400">Zylo</span>
            <span class="text-orange-400">Brains</span>
        </a>
    </p>

</div>
    </div>
</footer>
                                                    <script src="~/js/site.js"></script>
                                                    @await RenderSectionAsync("Scripts", required: false)
                                                </body>

                                            </html>





