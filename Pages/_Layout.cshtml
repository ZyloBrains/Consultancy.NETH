<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NETH Educational Consultancy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        primary: {
        DEFAULT: '#004aad',
        dark: '#003380',
        light: '#1a65d4'
        },
        secondary: {
        DEFAULT: '#f4c430',
        dark: '#d4ab00'
        },
        red: {
        DEFAULT: '#dc3545',
        dark: '#c82333'
        }
        }
        }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
        font-family: 'Inter', sans-serif;
        background: transparent !important;
        margin: 0;
        padding: 0;
        }

        html {
        background: transparent !important;
        }

        .nav-link {
        position: relative;
        display: inline-block;
        transition: color 0.3s ease;
        }

        .nav-link::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -4px;
        width: 0;
        height: 2px;
        background-color: #004aad;
        transition: width 0.3s ease;
        }

        .nav-link:hover::after {
        width: 100%;
        }
    </style>
</head>

<body>
    <!-- Navbar - White floating rounded bar -->
    <nav class="fixed top-3 left-1/2 transform -translate-x-1/2 w-[85%] max-w-7xl z-50 bg-white shadow-lg rounded-2xl"
         id="main-navbar">
        <div class="px-12">
            <div class="flex items-center justify-between py-1">
                <a href="/" class="flex items-center">
                    <img src="~/images/neth_logo.jpg" alt="NETH Logo" class="h-12 md:h-14 w-auto object-contain" />
                </a>
                <div class="hidden md:flex items-center space-x-6 ">
                    <a href="/" class="nav-link text-red-600 hover:text-blue-600 font-medium text-base">Home</a>
                    <a href="/courses"
                       class="nav-link text-red-600 hover:text-blue-600 font-medium text-base">Courses</a>
                    <a href="/countries"
                       class="nav-link text-red-600 hover:text-blue-600 font-medium text-base">Countries</a>
                    <a href="/teachers"
                       class="nav-link text-red-600 hover:text-blue-600 font-medium text-base">Teachers</a>
                    <a href="/blogs" class="nav-link text-red-600 hover:text-blue-600 font-medium text-base">Blogs</a>
                    <a href="/events" class="nav-link text-red-600 hover:text-blue-600 font-medium text-base">Events</a>
                    <a href="/about-us" class="nav-link text-red-600 hover:text-blue-600 font-medium text-base">About
                        Us</a>
                    </div>
                    <div class="flex items-center space-x-2">
                        <button class="relative w-9 h-9 bg-gray-200 rounded-full flex items-center justify-center" flex
                                items-center justify-center hover:bg-white/30 transition">
                            <i class="fa fa-user text-blue-600 text-sm"></i>
                            
                        </button>
                        
                        <a href="/contact"
                               class="hidden md:inline-block bg-white text-primary px-4 py-1.5 rounded-full hover:bg-blue-500 transition font-semibold text-sm">Get
                            Started</a>
                            <button class="md:hidden text-gray-700"
                                    onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                                <i class="fa fa-bars text-lg"></i>
                            </button>
                        </div>
                    </div>
                    <!-- Mobile Menu -->
                    <div id="mobile-menu" class="hidden md:hidden pb-3 border-t border-white/20">
                        <a href="/" class="block py-1.5 text-gray-700 text-sm">Home</a>
                        <a href="/courses" class="block py-1.5 text-gray-700 text-sm">Courses</a>
                        <a href="/countries" class="block py-1.5 text-gray-700 text-sm">Countries</a>
                        <a href="/teachers" class="block py-1.5 text-gray-700 text-sm">Teachers</a>
                        <a href="/blogs" class="block py-1.5 text-gray-700 text-sm">Blogs</a>
                        <a href="/events" class="block py-1.5 text-gray-700 text-sm">Events</a>
                        <a href="/about-us" class="block py-1.5 text-gray-700 text-sm">About Us</a>
                        <a href="/contact" class="block py-1.5 text-yellow-300 font-semibold text-sm">Get Started</a>
                    </div>
                </div>
            </nav>

            <main>
                @RenderBody()
            </main>

            <footer class="bg-gray-900 text-white pt-16 pb-8">
                <div class="container mx-auto px-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
                        <div>
                            <img src="~/images/neth_logo.jpg" alt="NETH Logo" class="h-12 w-auto mb-4" />
                            <p class="text-gray-400 mb-4">NETH Educational Consultancy is a leading education consultancy for
                                abroad study.</p>
                                <div class="flex space-x-3">
                                    <a href="#"
                                           class="w-10 h-10 bg-blue-600 rounded flex items-center justify-center hover:bg-blue-700 transition"><i
                                        class="fab fa-facebook-f"></i></a>
                                        <a href="#"
                                               class="w-10 h-10 bg-pink-600 rounded flex items-center justify-center hover:bg-pink-700 transition"><i
                                            class="fab fa-instagram"></i></a>
                                            <a href="#"
                                                   class="w-10 h-10 bg-blue-400 rounded flex items-center justify-center hover:bg-blue-500 transition"><i
                                                class="fab fa-twitter"></i></a>
                                            </div>
                                        </div>
                                        <div>
                                            <h4 class="text-lg font-semibold mb-4">Quick Links</h4>
                                            <ul class="space-y-2 text-gray-400">
                                                <li><a href="/courses" class="hover:text-white transition"><i
                                                    class="fa fa-chevron-right text-xs mr-2"></i>Courses</a></li>
                                                    <li><a href="/countries" class="hover:text-white transition"><i
                                                        class="fa fa-chevron-right text-xs mr-2"></i>Countries</a></li>
                                                        <li><a href="/blogs" class="hover:text-white transition"><i
                                                            class="fa fa-chevron-right text-xs mr-2"></i>Blogs</a></li>
                                                            <li><a href="/events" class="hover:text-white transition"><i
                                                                class="fa fa-chevron-right text-xs mr-2"></i>Events</a></li>
                                                                <li><a href="/contact" class="hover:text-white transition"><i
                                                                    class="fa fa-chevron-right text-xs mr-2"></i>Contact</a></li>
                                                                </ul>
                                                            </div>
                                                            <div>
                                                                <h4 class="text-lg font-semibold mb-4">Putalisadak Office</h4>
                                                                <ul class="space-y-3 text-gray-400">
                                                                    <li><i class="fa fa-phone mr-2 text-primary"></i>+977 01-4168340</li>
                                                                    <li><i class="fa fa-mobile mr-2 text-primary"></i>+977 9841012378</li>
                                                                    <li><i class="fa fa-envelope mr-2 text-primary"></i> neth.edu@gmail.com</li>
                                                                    <li><i class="fa fa-map-marker mr-2 text-primary"></i> Putalisadak-28, Kathmandu</li>
                                                                </ul>
                                                            </div>
                                                            <div>
                                                                <h4 class="text-lg font-semibold mb-4">Shorakhutte Office</h4>
                                                                <ul class="space-y-3 text-gray-400">
                                                                    <li><i class="fa fa-phone mr-2 text-primary"></i>(+977) 01-4383281</li>
                                                                    <li><i class="fa fa-mobile mr-2 text-primary"></i>+977 9841773655</li>
                                                                    <li><i class="fa fa-envelope mr-2 text-primary"></i> neth.edu@gmail.com</li>
                                                                    <li><i class="fa fa-map-marker mr-2 text-primary"></i> Sorhakhutte-16, Kathmandu</li>
                                                                </ul>
                                                            </div>
                                                        </div>
                                                        <div class="border-t border-gray-700 pt-8 text-center text-gray-400">
                                                            <p>&copy; @DateTime.Now.Year NETH Educational Consultancy. All rights reserved. | Designed by Zylo
                                                                Brains Pvt. Ltd.</p>
                                                            </div>
                                                        </div>
                                                    </footer>

                                                    <script src="~/js/site.js"></script>
                                                    @await RenderSectionAsync("Scripts", required: false)
                                                </body>

                                            </html>





