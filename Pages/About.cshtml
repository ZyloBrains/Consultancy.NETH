@page "/about-us"
@{
    ViewData["Title"] = "About Us";
}

<section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-4xl font-bold text-center mb-12">Who We Are</h1>
        <div class="bg-white rounded-xl shadow-lg p-8 md:p-12">
            <h2 class="text-2xl font-bold mb-6">About Us</h2>
            <p class="text-gray-600 mb-4">We are a leading education consultancy providing expert consultation for students who want to study abroad.</p>
            <p class="text-gray-600 mb-4">Our team consists of experienced teachers and counselors who will assist you every step of the way.</p>
            <ul class="space-y-3 mt-6">
                <li class="flex items-center text-gray-600">✓ Access to 100+ top universities</li>
                <li class="flex items-center text-gray-600">✓ Explore a variety of fresh topics</li>
                <li class="flex items-center text-gray-600">✓ Find the right instructor for you</li>
            </ul>
        </div>
    </div>
</section>