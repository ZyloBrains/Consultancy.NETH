@page
@model BlogsModel
@inject IBlogService BlogService
@{
    var blogs = await BlogService.GetAllAsync();
    ViewData["Title"] = "Blogs";
}

<section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
        <h1 class="text-4xl font-bold text-center mb-12">Blogs</h1>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @foreach (var blog in blogs)
            {
                <div class="bg-white rounded-xl shadow-md overflow-hidden">
                    <div class="h-48 bg-gray-200"></div>
                    <div class="p-6">
                        <p class="text-sm text-gray-500 mb-2">@blog.CreatedAt.ToString("dd-MM-yyyy")</p>
                        <h3 class="text-lg font-bold mb-2">@blog.Title</h3>
                        <a href="/blogs/@blog.Slug" class="text-blue-600 font-medium">Read More →</a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@functions {
    public class BlogsModel : PageModel { public async Task OnGet() => await Task.CompletedTask; }
}