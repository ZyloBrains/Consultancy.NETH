@page "/"
@model Consultancy.NETH.Pages.IndexModel
@inject Consultancy.Services.ICourseService CourseService
@inject Consultancy.Services.ICountryService CountryService
@inject Consultancy.Services.ITeacherService TeacherService
@inject Consultancy.Services.IEventService EventService

@{
    ViewData["Title"] = "NETH Educational Consultancy - Study Abroad";
    var stats = new { Students = 5000, Universities = 100, SuccessRate = 95, Countries = Model.Countries.Count() };
    var teachers = await TeacherService.GetFeaturedAsync();
}

<!-- Hero Section with NETH Image Slider - Full screen, no white gap -->
<!-- Hero Section -->
<div class="relative h-[70vh] sm:h-[80vh] md:h-[95vh] flex items-center overflow-hidden" id="hero-slider"
     onmouseenter="pauseSlider()" onmouseleave="resumeSlider()">

    <!-- Image Slider -->
    <div class="absolute inset-0 z-0 overflow-hidden">
        <div id="slider-track"
             class="flex h-full transition-transform duration-700 ease-in-out"
             style="transform: translateX(0%);">

            <img src="/images/neth-5.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-2.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-3.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-4.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-8.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
        </div>

        <!-- Left Arrow -->
        <button onclick="prevSlide()"
                class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 z-30 w-9 h-9 sm:w-12 sm:h-12 bg-red-500 hover:bg-red-600 rounded-full flex items-center justify-center text-white text-sm sm:text-2xl shadow-lg">
            <i class="fa fa-chevron-left"></i>
        </button>

        <!-- Right Arrow -->
        <button onclick="nextSlide()"
                class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 z-30 w-9 h-9 sm:w-12 sm:h-12 bg-red-500 hover:bg-red-600 rounded-full flex items-center justify-center text-white text-sm sm:text-2xl shadow-lg">
            <i class="fa fa-chevron-right"></i>
        </button>

      <div class="absolute bottom-20 sm:bottom-28 md:bottom-36 left-1/2 -translate-x-1/2 z-30 flex gap-2 sm:gap-3">
    <button onclick="goToSlide(0)" id="dot-0" class="dot w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-white/50"></button>
    <button onclick="goToSlide(1)" id="dot-1" class="dot w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-white/50"></button>
    <button onclick="goToSlide(2)" id="dot-2" class="dot w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-white/50"></button>
    <button onclick="goToSlide(3)" id="dot-3" class="dot w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-white/50"></button>
    <button onclick="goToSlide(4)" id="dot-4" class="dot w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-white/50"></button>
</div>
    </div>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/25 to-transparent z-10 pointer-events-none"></div>

    <!-- Content -->
    <div class="relative z-20 ml-4 sm:ml-6 md:ml-16 lg:ml-24 text-white max-w-xl sm:max-w-2xl">

        <!-- Badge -->
        <div class="mb-2 sm:mb-3 inline-block px-2 sm:px-3 py-1 sm:py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-xs font-medium">
            <i class="fa fa-graduation-cap mr-1"></i> Trusted by @stats.Students.ToString("0,0")+ Students
        </div>

        <!-- Heading -->
        <h1 class="text-xl sm:text-2xl md:text-4xl lg:text-5xl xl:text-6xl font-extrabold mb-3 sm:mb-4 leading-tight">
            Start Your International <span class="text-red-500">Education</span> Journey
        </h1>

        <!-- Paragraph -->
        <p class="text-xs sm:text-sm md:text-base mb-5 sm:mb-7 text-gray-200 max-w-lg">
            Join thousands of students who trusted NETH for expert counseling, university placement, and visa success.
        </p>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 mb-6 sm:mb-8">
            <a href="/courses"
               class="text-white px-4 sm:px-6 py-2 sm:py-2.5 rounded-full font-semibold text-xs sm:text-sm bg-red-500 hover:bg-red-600 transition text-center">
                <i class="fa fa-search mr-1"></i> Explore Courses
            </a>

            <a href="/contact"
               class="border border-white text-white px-4 sm:px-6 py-2 sm:py-2.5 rounded-full font-semibold text-xs sm:text-sm hover:bg-white hover:text-black transition text-center">
                <i class="fa fa-phone mr-1"></i> Free Consultation
            </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 sm:gap-3">
            <div>
                <div class="text-xl sm:text-2xl md:text-3xl font-bold">@stats.Students.ToString("0,0")+</div>
                <div class="text-xs text-gray-300">Students</div>
            </div>
            <div>
                <div class="text-xl sm:text-2xl md:text-3xl font-bold">@stats.Universities+</div>
                <div class="text-xs text-gray-300">Universities</div>
            </div>
            <div>
                <div class="text-xl sm:text-2xl md:text-3xl font-bold">@stats.SuccessRate%</div>
                <div class="text-xs text-gray-300">Success</div>
            </div>
            <div>
                <div class="text-xl sm:text-2xl md:text-3xl font-bold">@stats.Countries+</div>
                <div class="text-xs text-gray-300">Countries</div>
            </div>
        </div>

    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 sm:bottom-16 md:bottom-24 left-1/2 -translate-x-1/2 text-white animate-bounce z-30">
    <i class="fa fa-chevron-down text-xl sm:text-2xl"></i>
</div>

</div>

<!-- 3 Info Boxes Overlapping Section Divider -->
<div class="relative z-30 -mt-12 sm:-mt-16 md:-mt-20 px-4 max-w-4xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6">

        <!-- BOX 1 -->
        <div class="bg-white/90 backdrop-blur-md rounded-xl shadow-lg p-6 
