<!-- Top Destinations Section -->
<section class="py-12 sm:py-16 md:py-18 bg-gradient-to-b from-gray-50 to-white relative overflow-hidden">

    <!-- Background Glow -->
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 left-10 w-40 h-40 bg-red-500 rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-52 h-52 bg-red-400 rounded-full blur-3xl"></div>

        </div>

    <div class="container mx-auto px-4 relative z-10">

        <!-- Heading -->
        <div class="text-center mb-16">

            <div class="inline-flex items-center gap-3 bg-red-500/10 backdrop-blur-md px-6 py-2.5 rounded-full mb-6 shadow-md border border-red-200">
                <span class="text-red-600 font-semibold text-sm uppercase tracking-wider">
                    Study Destinations
                </span>
            </div>

            <h2 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight">
                Explore Your 
                <span class="bg-gradient-to-r from-red-500 via-red-600 to-red-500 bg-clip-text text-transparent">
                    Dream Country
                </span>
            </h2>

            <p class="text-gray-600 max-w-2xl mx-auto text-lg">
                Discover world-class education destinations with 
                <span class="font-semibold text-red-600">NETH’s expert guidance</span>.
            </p>

        </div>

        <!-- Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

            @foreach (var country in Model.Countries.Take(4))
            {
                <a href="/countries/@country.Slug"
                   class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-1">

                    <!-- Image -->
                    <img src="~/images/neth-@(country.Id % 4 + 1).jpg"
                         class="absolute inset-0 w-full h-full object-cover transition duration-700 group-hover:scale-110">

                    <!-- Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>

                    <!-- Content -->
                    <div class="relative z-10 p-4 flex flex-col justify-end h-[260px] text-white">

                        <!-- Tag -->
                        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-md px-3 py-1 rounded-full text-xs mb-2 w-fit">
                            <i class="fa fa-map-marker"></i>
                            Study in
                        </div>

                        <!-- Country -->
                        <h3 class="text-xl font-bold mb-1 tracking-wide">
                            @country.Name
                        </h3>

                        <!-- Description -->
                        <p class="text-xs text-gray-200 opacity-0 translate-y-3 group-hover:opacity-100 group-hover:translate-y-0 transition duration-500">
                            @(country.Description ?? "Explore top universities and opportunities")
                        </p>

                        <!-- CTA -->
                        <div class="mt-3 flex items-center gap-2 text-red-400 text-sm opacity-0 group-hover:opacity-100 transition duration-500">
                            <span class="font-semibold">Explore</span>
                            <i class="fa fa-arrow-right group-hover:translate-x-1 transition"></i>
                        </div>

                    </div>

                    <!-- Border Hover -->
                    <div class="absolute inset-0 rounded-2xl border border-transparent group-hover:border-red-300/40 transition"></div>

                </a>
            }

        </div>

        <!-- Button -->
        <div class="text-center mt-12">
            <a href="/countries"
               class="inline-flex items-center gap-3 px-7 py-3 rounded-full font-semibold text-white 
                      bg-gradient-to-r from-red-500 to-red-600 
                      hover:from-red-600 hover:to-red-500 
                      transition duration-300 shadow-lg shadow-red-300/40 hover:shadow-xl hover:scale-105">

                View All Countries
                <i class="fa fa-arrow-right"></i>
            </a>
        </div>

    </div>
</section>                            <!-- Featured Courses -->
