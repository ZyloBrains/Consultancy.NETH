@page "/"
@model IndexModel
@inject ICourseService CourseService
@inject ICountryService CountryService
@inject ITeacherService TeacherService
@inject IBlogService BlogService

@{
    ViewData["Title"] = "NETH Educational Consultancy - Study Abroad";
    var courses = await CourseService.GetFeaturedAsync();
    var countries = await CountryService.GetFeaturedAsync(4);
    var teachers = await TeacherService.GetFeaturedAsync();
    var blogs = await BlogService.GetRecentAsync(3);
    var stats = new { Students = 5000, Universities = 100, SuccessRate = 95, Countries = countries.Count() };
}

<!-- Hero Section with NETH Image Slider - Full screen, no white gap -->
<!-- Hero Section -->
<div class="relative h-[95vh] flex items-center overflow-hidden" id="hero-slider"
     onmouseenter="pauseSlider()" onmouseleave="resumeSlider()">

    <!-- Image Slider -->
    <div class="absolute inset-0 z-0 overflow-hidden">
        <div id="slider-track"
             class="flex h-full transition-transform duration-700 ease-in-out"
             style="transform: translateX(0%);">

            <img src="/images/neth-5.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-2.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-3.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-4.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
            <img src="/images/neth-8.jpg" class="slider-img brightness-75 contrast-110 saturate-125">
        </div>

        <!-- Left Arrow -->
        <button onclick="prevSlide()"
                class="absolute left-4 top-1/2 -translate-y-1/2 z-30 w-12 h-12 bg-red-500 hover:bg-red-600 rounded-full flex items-center justify-center text-white text-2xl shadow-lg">
            <i class="fa fa-chevron-left"></i>
        </button>

        <!-- Right Arrow -->
        <button onclick="nextSlide()"
                class="absolute right-4 top-1/2 -translate-y-1/2 z-30 w-12 h-12 bg-red-500 hover:bg-red-600 rounded-full flex items-center justify-center text-white text-2xl shadow-lg">
            <i class="fa fa-chevron-right"></i>
        </button>

        <!-- Dots -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 flex gap-3">
            <button onclick="goToSlide(0)" id="dot-0" class="dot w-3 h-3 rounded-full bg-white/50"></button>
            <button onclick="goToSlide(1)" id="dot-1" class="dot w-3 h-3 rounded-full bg-white/50"></button>
            <button onclick="goToSlide(2)" id="dot-2" class="dot w-3 h-3 rounded-full bg-white/50"></button>
            <button onclick="goToSlide(3)" id="dot-3" class="dot w-3 h-3 rounded-full bg-white/50"></button>
            <button onclick="goToSlide(4)" id="dot-4" class="dot w-3 h-3 rounded-full bg-white/50"></button>
        </div>
    </div>

    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/25 to-transparent z-10 pointer-events-none"></div>

    <!-- Content -->
    <div class="relative z-20 ml-6 md:ml-16 lg:ml-24 text-white max-w-2xl">

        <!-- Badge -->
        <div class="mb-3 inline-block px-3 py-1.5 bg-white/20 backdrop-blur-sm rounded-full text-xs font-medium">
            <i class="fa fa-graduation-cap mr-1"></i> Trusted by @stats.Students+ Students
        </div>

        <!-- Heading -->
        <h1 class="text-2xl md:text-4xl lg:text-6xl font-extrabold mb-4 leading-tight">
            Start Your International <span class="text-red-500">Education</span> Journey
        </h1>

        <!-- Paragraph -->
        <p class="text-sm md:text-base mb-7 text-gray-200 max-w-lg">
            Join thousands of students who trusted NETH for expert counseling, university placement, and visa success.
        </p>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="/courses"
               class="text-white px-6 py-2.5 rounded-full font-semibold text-sm bg-red-500 hover:bg-red-600 transition">
                <i class="fa fa-search mr-1"></i> Explore Courses
            </a>

            <a href="/contact"
               class="border border-white text-white px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-white hover:text-black transition">
                <i class="fa fa-phone mr-1"></i> Free Consultation
            </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div>
                <div class="text-2xl md:text-3xl font-bold">@stats.Students.ToString("0,0")+</div>
                <div class="text-xs text-gray-300">Students</div>
            </div>
            <div>
                <div class="text-2xl md:text-3xl font-bold">@stats.Universities+</div>
                <div class="text-xs text-gray-300">Universities</div>
            </div>
            <div>
                <div class="text-2xl md:text-3xl font-bold">@stats.SuccessRate%</div>
                <div class="text-xs text-gray-300">Success</div>
            </div>
            <div>
                <div class="text-2xl md:text-3xl font-bold">@stats.Countries+</div>
                <div class="text-xs text-gray-300">Countries</div>
            </div>
        </div>

    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white animate-bounce z-30">
        <i class="fa fa-chevron-down text-2xl"></i>
    </div>

</div>

