<!-- Hero Slider CSS & JS -->
<style>
    .slider-container {
        position: relative;
        width: 100%;
        height: 100%;
    }

    .slider-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 1.5s ease-in-out;
    }

    .slider-img.active {
        opacity: 1;
    }
</style>

<script>
    // Hero Image Slider
    const images = document.querySelectorAll('.slider-img');
    let current = 0;

    function showSlide(n) {
        images[current].classList.remove('active');
        current = (current + n + images.length) % images.length;
        images[current].classList.add('active');
    }

    function nextSlide() {
        showSlide(1);
    }

    function prevSlide() {
        showSlide(-1);
    }

    // Initial active
    if (images.length > 0) {
        images[0].classList.add('active');
    }

    // Click on images to change slide
    images.forEach((img, index) => {
        img.addEventListener('click', () => {
            images[current].classList.remove('active');
            current = index;
            images[current].classList.add('active');
        });
    });

    // Change slide every 8 seconds (slower)
    setInterval(nextSlide, 8000);
</script>
