                <i class="fa fa-passport text-red-500 text-lg group-hover:text-white"></i>
            </div>

            <h3 class="text-lg font-bold text-gray-800 mb-2">Visa Assistance</h3>

            <p class="text-gray-500 text-sm leading-relaxed">
                95% visa success with full documentation support.
            </p>

            <a href="/about-us"
               class="inline-flex items-center gap-1 mt-4 text-red-500 font-semibold text-sm 
                      hover:gap-2 transition-all">
                Learn More <i class="fa fa-arrow-right text-xs"></i>
            </a>

            <div class="absolute bottom-0 left-0 h-1 w-0 bg-red-500 group-hover:w-full transition-all"></div>
        </div>


        <!-- BOX 3 -->
        <div class="bg-white/90 backdrop-blur-md rounded-xl shadow-lg p-6 
                    hover:-translate-y-2 hover:shadow-2xl transition duration-300 
                    group relative border border-gray-100">

            <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4 
                        group-hover:bg-yellow-400 transition">
                <i class="fa fa-globe text-yellow-500 text-lg group-hover:text-black"></i>
            </div>

            <h3 class="text-lg font-bold text-gray-800 mb-2">Global Universities</h3>

            <p class="text-gray-500 text-sm leading-relaxed">
                Access to 100+ universities across top countries.
            </p>

            <a href="/countries"
               class="inline-flex items-center gap-1 mt-4 text-red-500 font-semibold text-sm 
                      hover:gap-2 transition-all">
                Explore <i class="fa fa-arrow-right text-xs"></i>
            </a>

            <div class="absolute bottom-0 left-0 h-1 w-0 bg-red-500 group-hover:w-full transition-all"></div>
        </div>

    </div>
</div>
